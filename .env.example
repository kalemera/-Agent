# ─── EVDS API ────────────────────────────────────────────────────────────────
# TCMB EVDS API anahtarı (sync-evds-catalog komutu için zorunlu)
EVDS_API_KEY=your_evds_api_key_here
# Opsiyonel: varsayılan https://evds3.tcmb.gov.tr/igmevdsms-dis/
# EVDS_BASE_URL=https://evds3.tcmb.gov.tr/igmevdsms-dis/

# ─── LLM (Semantic Inference) ────────────────────────────────────────────────
# Hangi sağlayıcı: qwen | ollama | disabled
LLM_PROVIDER=qwen

# --- Qwen / Alibaba Cloud DashScope (LLM_PROVIDER=qwen) ---
QWEN_API_KEY=sk-your_dashscope_api_key_here
# Model seçenekleri: qwen-turbo (hızlı/ucuz) | qwen-plus | qwen-max
QWEN_MODEL=qwen-turbo
# Opsiyonel: varsayılan DashScope OpenAI-compat endpoint
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Ollama Local (LLM_PROVIDER=ollama) ---
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://127.0.0.1:11434/api/

# --- Ollama Cloud (LLM_PROVIDER=ollama, cloud model) ---
# OLLAMA_MODEL=qwen2.5:7b-cloud
# OLLAMA_CLOUD_API_KEY=your_ollama_cloud_key
# OLLAMA_CLOUD_BASE_URL=https://ollama.com/api/

# Opsiyonel: LLM zaman aşımı (saniye), varsayılan 60
# LLM_TIMEOUT_SEC=60
